generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum ArticleType {
  SIMPLE
  KIT
  COMPONENT
}

enum ProductType {
  FINI
  EBAUCHE
  MATIERE_PREMIERE
  DEMO
}

enum MovementDirection {
  ENTREE
  SORTIE
}

enum MovementType {
  RECEIPT
  ISSUE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  KIT_BUILD
  KIT_BREAK
}

enum LotStatus {
  AVAILABLE
  RESERVED
  CONSUMED
  QUARANTINED
}

enum DocStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_DELIVERED
  DELIVERED
  INVOICED
  CLOSED
}

enum PriceScope {
  GLOBAL
  COUNTRY
  CUSTOMER
  CUSTOMER_GROUP
}

// ─────────────────────────────────────────────
// UTILISATEURS
// ─────────────────────────────────────────────

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  role      String     @default("stock")
  createdAt DateTime   @default(now())

  movements Movement[]
}

// ─────────────────────────────────────────────
// ENTREPÔTS & EMPLACEMENTS
// ─────────────────────────────────────────────

model Warehouse {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())

  locations Location[]
}

model Location {
  id            Int        @id @default(autoincrement())
  warehouseId   Int
  code          String
  label         String

  warehouse     Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  movementsFrom Movement[] @relation("FromLocation")
  movementsTo   Movement[] @relation("ToLocation")

  @@unique([warehouseId, code])
}

// ─────────────────────────────────────────────
// FOURNISSEURS
// ─────────────────────────────────────────────

model Supplier {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  name          String
  address       String?
  cp            String?
  city          String?
  countryId     Int?
  phone         String?
  email         String?
  contact1      String?
  phone1        String?
  email1        String?
  langue        String?   @default("FR")
  delaiHabituel Int?      // délai de livraison habituel en jours
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  country        Country?        @relation(fields: [countryId], references: [id], onDelete: SetNull)
  purchaseOrders PurchaseOrder[]
  lots           StockLot[]      // lots reçus de ce fournisseur

  @@index([countryId])
}

// ─────────────────────────────────────────────
// PAYS / GROUPES CLIENTS / CLIENTS
// ─────────────────────────────────────────────

model Country {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())

  customers  Customer[]
  suppliers  Supplier[]
  priceLists PriceList[]
}

model CustomerGroup {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())

  customers  Customer[]
  priceLists PriceList[]
}

model Customer {
  id                 Int            @id @default(autoincrement())
  code               String         @unique
  // Identité
  prenom             String?
  nom                String?
  etablissement      String?
  // Coordonnées
  phone              String?
  email              String?
  langue             String?        @default("FR")
  numTVA             String?
  // Adresse de livraison
  adresseLivraison   String?
  cpLivraison        String?
  villeLivraison     String?
  // Adresse de facturation (peut être différente)
  adresseFacturation String?
  cpFacturation      String?
  villeFacturation   String?
  // Contact BL
  contactBL          String?
  telBL              String?
  // Contact facturation
  contactFact        String?
  telFact            String?
  // Paramètres commerciaux
  fraisDePort        Decimal?       @db.Decimal(18, 2)
  codeTarif          String?
  // Relations
  countryId          Int?
  groupId            Int?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  country    Country?       @relation(fields: [countryId], references: [id], onDelete: SetNull)
  group      CustomerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  orders     SalesOrder[]
  priceLists PriceList[]

  @@index([countryId])
  @@index([groupId])
}

// ─────────────────────────────────────────────
// TARIFS
// ─────────────────────────────────────────────

model PriceList {
  id              Int            @id @default(autoincrement())
  code            String         @unique
  name            String
  scope           PriceScope     @default(GLOBAL)
  countryId       Int?
  customerId      Int?
  customerGroupId Int?
  currency        String         @default("EUR")
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  country       Country?       @relation(fields: [countryId], references: [id], onDelete: SetNull)
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerGroup CustomerGroup? @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)
  items         PriceListItem[]

  @@index([scope])
  @@index([countryId])
  @@index([customerId])
  @@index([customerGroupId])
}

model PriceListItem {
  id          Int       @id @default(autoincrement())
  priceListId Int
  articleId   Int
  unitPrice   Decimal   @db.Decimal(18, 4)
  minQty      Decimal?  @db.Decimal(18, 4)
  validFrom   DateTime?
  validTo     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([priceListId, articleId])
  @@index([articleId])
}

// ─────────────────────────────────────────────
// ARTICLES
// ─────────────────────────────────────────────

model Article {
  id            Int          @id @default(autoincrement())
  code          String       @unique
  indice        String?
  designationFr String       @default("")
  designationEn String?
  etat          String?
  famille       String?
  sousFamille   String?
  // Caractéristiques physiques (utilisées pour construire la désignation)
  diametre      String?
  longueur      String?
  largeur       String?
  autreCarac    String?
  // Type de produit
  typeProduit   ProductType? @default(FINI)
  // Prix de référence (le vrai coût vient des lots/achats)
  prixAchatRef  Decimal?     @db.Decimal(18, 4)
  // Stock
  stockMin      Decimal?     @db.Decimal(18, 3)
  stockSecurite Decimal?     @db.Decimal(18, 3)
  // Commentaire libre
  commentaire   String?
  // Statut & type
  isActive      Boolean      @default(true)
  type          ArticleType  @default(SIMPLE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  lots          StockLot[]
  movements     Movement[]
  movementLines StockMovementLine[]
  parentKits    KitComponent[]      @relation("KitParent")
  childKits     KitComponent[]      @relation("KitChild")
  salesLines    SalesOrderLine[]
  purchaseLines PurchaseOrderLine[]
  priceItems    PriceListItem[]

  @@index([type])
  @@index([isActive])
  @@index([code])
}

// ─────────────────────────────────────────────
// KITS
// ─────────────────────────────────────────────

model KitComponent {
  id              Int     @id @default(autoincrement())
  parentArticleId Int
  childArticleId  Int
  quantity        Decimal @db.Decimal(18, 3)

  parentArticle Article @relation("KitParent", fields: [parentArticleId], references: [id], onDelete: Cascade)
  childArticle  Article @relation("KitChild", fields: [childArticleId], references: [id], onDelete: Restrict)

  @@unique([parentArticleId, childArticleId])
  @@index([childArticleId])
}

// ─────────────────────────────────────────────
// STOCK — LOTS
// ─────────────────────────────────────────────

model StockLot {
  id            Int       @id @default(autoincrement())
  articleId     Int
  lotNumber     String
  quantity      Decimal   @db.Decimal(18, 3)
  status        LotStatus @default(AVAILABLE)
  // Coût réel de ce lot (déterminé à la réception de la commande fournisseur)
  coutRevient   Decimal?  @db.Decimal(18, 4)
  supplierId    Int?
  receivedAt    DateTime?
  expiryDate    DateTime?
  location      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements Movement[]
  lines     StockMovementLine[]

  @@unique([articleId, lotNumber])
  @@index([articleId])
  @@index([supplierId])
  @@index([status])
}

// ─────────────────────────────────────────────
// STOCK — MOTIFS DE MOUVEMENT
// ─────────────────────────────────────────────

model MovementReason {
  id        Int               @id @default(autoincrement())
  code      String            @unique
  label     String
  direction MovementDirection // ENTREE ou SORTIE
  isActive  Boolean           @default(true)

  movements Movement[]
}

// ─────────────────────────────────────────────
// STOCK — MOUVEMENTS
// ─────────────────────────────────────────────

model Movement {
  id             Int               @id @default(autoincrement())
  movedAt        DateTime          @default(now())
  direction      MovementDirection
  type           MovementType
  quantity       Decimal           @db.Decimal(18, 4)
  referenceType  String
  referenceId    String
  note           String?
  reasonId       Int?
  itemId         Int
  lotId          Int?
  createdById    Int
  fromLocationId Int?
  toLocationId   Int?

  reason       MovementReason? @relation(fields: [reasonId], references: [id], onDelete: SetNull)
  item         Article         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot          StockLot?       @relation(fields: [lotId], references: [id], onDelete: SetNull)
  createdBy    User            @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fromLocation Location?       @relation("FromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation   Location?       @relation("ToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  lines        StockMovementLine[]

  @@index([itemId])
  @@index([lotId])
  @@index([movedAt])
  @@index([reasonId])
}

model StockMovementLine {
  id              Int                @id @default(autoincrement())
  movementId      Int
  articleId       Int
  lotId           Int?
  quantity        Decimal            @db.Decimal(18, 3)
  unitCost        Decimal?           @db.Decimal(18, 4)
  sourceLotNumber String?
  targetLotNumber String?
  isKitExplosion  Boolean            @default(false)
  parentLineId    Int?

  movement   Movement           @relation(fields: [movementId], references: [id], onDelete: Cascade)
  article    Article            @relation(fields: [articleId], references: [id], onDelete: Restrict)
  lot        StockLot?          @relation(fields: [lotId], references: [id], onDelete: SetNull)
  parentLine StockMovementLine? @relation("LineTree", fields: [parentLineId], references: [id], onDelete: SetNull)
  children   StockMovementLine[] @relation("LineTree")

  @@index([movementId])
  @@index([articleId])
  @@index([lotId])
}

// ─────────────────────────────────────────────
// COMMANDES CLIENT
// ─────────────────────────────────────────────

model SalesOrder {
  id               Int       @id @default(autoincrement())
  number           String    @unique
  customerId       Int?
  status           DocStatus @default(DRAFT)
  referenceClient  String?
  numDevis         String?
  devise           String    @default("EUR")
  delai            String?
  createdAt        DateTime  @default(now())
  dateFacturation  DateTime?
  dateEncaissement DateTime?
  prixTotal        Decimal?  @db.Decimal(18, 2)
  commentaire      String?

  customer      Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines         SalesOrderLine[]
  deliveryNotes DeliveryNote[]

  @@index([customerId])
}

model SalesOrderLine {
  id        Int      @id @default(autoincrement())
  orderId   Int
  itemId    Int
  qty       Decimal  @db.Decimal(18, 4)
  qtyDone   Decimal  @default(0) @db.Decimal(18, 4)
  unitPrice Decimal? @db.Decimal(18, 4)
  prixTotal Decimal? @db.Decimal(18, 4)

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  Article    @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([itemId])
}

// ─────────────────────────────────────────────
// COMMANDES FOURNISSEUR
// ─────────────────────────────────────────────

model PurchaseOrder {
  id                  Int       @id @default(autoincrement())
  number              String    @unique
  supplierId          Int?
  status              DocStatus @default(DRAFT)
  createdAt           DateTime  @default(now())
  dateLivraisonPrevue DateTime?
  dateLivraisonReelle DateTime?
  commentaire         String?

  supplier Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines    PurchaseOrderLine[]

  @@index([supplierId])
}

model PurchaseOrderLine {
  id        Int      @id @default(autoincrement())
  orderId   Int
  itemId    Int
  qty       Decimal  @db.Decimal(18, 4)
  qtyDone   Decimal  @default(0) @db.Decimal(18, 4)
  unitPrice Decimal? @db.Decimal(18, 4)

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  Article       @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([itemId])
}

// ─────────────────────────────────────────────
// BONS DE LIVRAISON & FACTURES
// ─────────────────────────────────────────────

model DeliveryNote {
  id        Int       @id @default(autoincrement())
  number    String    @unique
  orderId   Int
  status    DocStatus @default(DRAFT)
  createdAt DateTime  @default(now())

  order    SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([orderId])
}

model Invoice {
  id               Int       @id @default(autoincrement())
  number           String    @unique
  blId             Int
  status           DocStatus @default(DRAFT)
  amount           Decimal   @db.Decimal(18, 2)
  createdAt        DateTime  @default(now())
  dateEcheance     DateTime?
  dateEncaissement DateTime?
  commentaire      String?

  deliveryNote DeliveryNote @relation(fields: [blId], references: [id], onDelete: Cascade)

  @@index([blId])
}
