generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum ArticleType {
  SIMPLE
  KIT
  COMPONENT
}

enum ProductType {
  FINI
  EBAUCHE
  MATIERE_PREMIERE
  DEMO
}

enum MovementDirection {
  ENTREE
  SORTIE
}

enum MovementType {
  RECEIPT
  ISSUE
  TRANSFER_IN
  TRANSFER_OUT
  TRANSFER
  ADJUSTMENT
  KIT_BUILD
  KIT_BREAK
  LOAN_OUT
  LOAN_IN
  DEMO_OUT
  DEMO_IN
}

enum LotStatus {
  AVAILABLE
  RESERVED
  CONSUMED
  QUARANTINED
}

enum DocStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_DELIVERED
  DELIVERED
  INVOICED
  CLOSED
}

enum PriceScope {
  GLOBAL
  COUNTRY
  CUSTOMER
  CUSTOMER_GROUP
}

enum LocationType {
  SHELF
  DEMO
  LOAN
  TRANSIT
  QUARANTINE
  OTHER
}

enum KitLoanType {
  DEMO
  LOAN
  SALE
}

enum KitLoanStatus {
  EN_COURS
  RETOURNE
  VENDU
}

// ─────────────────────────────────────────────
// UTILISATEURS
// ─────────────────────────────────────────────

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  role      String     @default("stock")
  createdAt DateTime   @default(now())

  movements Movement[]
}

// ─────────────────────────────────────────────
// ENTREPÔTS & EMPLACEMENTS
// ─────────────────────────────────────────────

model Warehouse {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())

  locations Location[]
}

model Location {
  id          Int          @id @default(autoincrement())
  warehouseId Int
  code        String
  label       String
  type        LocationType @default(SHELF)
  customerId  Int?
  reference   String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  warehouse     Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  customer      Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  movementsFrom Movement[] @relation("FromLocation")
  movementsTo   Movement[] @relation("ToLocation")
  lots          StockLot[]

  @@unique([warehouseId, code])
  @@index([customerId])
  @@index([type])
}

// ─────────────────────────────────────────────
// FOURNISSEURS
// ─────────────────────────────────────────────

model Supplier {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  name          String
  address       String?
  cp            String?
  city          String?
  countryId     Int?
  phone         String?
  email         String?
  contact1      String?
  phone1        String?
  email1        String?
  langue        String?   @default("FR")
  delaiHabituel Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  country        Country?        @relation(fields: [countryId], references: [id], onDelete: SetNull)
  purchaseOrders PurchaseOrder[]
  lots           StockLot[]
  supplierPrices SupplierPrice[]

  @@index([countryId])
}

// ─────────────────────────────────────────────
// TARIFS FOURNISSEUR
// ─────────────────────────────────────────────

model SupplierPrice {
  id             Int       @id @default(autoincrement())
  supplierId     Int
  articleId      Int
  unitPrice      Decimal   @db.Decimal(18, 4)
  qtyMin         Decimal?  @db.Decimal(18, 3)
  refDevis       String?
  dateDevis      DateTime?
  validFrom      DateTime?
  validTo        DateTime?
  currency       String    @default("EUR")
  note           String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  article  Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([articleId])
  @@index([supplierId, articleId])
}

// ─────────────────────────────────────────────
// PAYS / GROUPES CLIENTS / CLIENTS
// ─────────────────────────────────────────────

model Country {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())

  customers  Customer[]
  suppliers  Supplier[]
  priceLists PriceList[]
}

model CustomerGroup {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())

  customers  Customer[]
  priceLists PriceList[]
}

model Customer {
  id                 Int            @id @default(autoincrement())
  code               String         @unique
  prenom             String?
  nom                String?
  etablissement      String?
  phone              String?
  email              String?
  langue             String?        @default("FR")
  numTVA             String?
  adresseLivraison   String?
  cpLivraison        String?
  villeLivraison     String?
  adresseFacturation String?
  cpFacturation      String?
  villeFacturation   String?
  contactBL          String?
  telBL              String?
  contactFact        String?
  telFact            String?
  fraisDePort        Decimal?       @db.Decimal(18, 2)
  codeTarif          String?
  countryId          Int?
  groupId            Int?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  country    Country?       @relation(fields: [countryId], references: [id], onDelete: SetNull)
  group      CustomerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  orders     SalesOrder[]
  priceLists PriceList[]
  locations  Location[]
  kitLoans   KitLoan[]

  @@index([countryId])
  @@index([groupId])
}

// ─────────────────────────────────────────────
// TARIFS CLIENT (grilles avancées — optionnel)
// ─────────────────────────────────────────────

model PriceList {
  id              Int            @id @default(autoincrement())
  code            String         @unique
  name            String
  scope           PriceScope     @default(GLOBAL)
  countryId       Int?
  customerId      Int?
  customerGroupId Int?
  currency        String         @default("EUR")
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  country       Country?       @relation(fields: [countryId], references: [id], onDelete: SetNull)
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerGroup CustomerGroup? @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)
  items         PriceListItem[]

  @@index([scope])
  @@index([countryId])
  @@index([customerId])
  @@index([customerGroupId])
}

model PriceListItem {
  id          Int       @id @default(autoincrement())
  priceListId Int
  articleId   Int
  unitPrice   Decimal   @db.Decimal(18, 4)
  minQty      Decimal?  @db.Decimal(18, 4)
  validFrom   DateTime?
  validTo     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([priceListId, articleId])
  @@index([articleId])
}

// ─────────────────────────────────────────────
// ARTICLES
// ─────────────────────────────────────────────

model Article {
  id            Int          @id @default(autoincrement())
  code          String       @unique
  indice        String?
  designationFr String       @default("")
  designationEn String?
  etat          String?
  famille       String?
  sousFamille   String?
  diametre      String?
  longueur      String?
  largeur       String?
  autreCarac    String?
  typeProduit   ProductType? @default(FINI)
  prixAchatRef  Decimal?     @db.Decimal(18, 4)
  stockMin      Decimal?     @db.Decimal(18, 3)
  stockSecurite Decimal?     @db.Decimal(18, 3)
  // ── Tarifs de vente (0 = public, 1 à 6 = grilles clients) ──
  prix0         Decimal?     @db.Decimal(18, 4)
  prix1         Decimal?     @db.Decimal(18, 4)
  prix2         Decimal?     @db.Decimal(18, 4)
  prix3         Decimal?     @db.Decimal(18, 4)
  prix4         Decimal?     @db.Decimal(18, 4)
  prix5         Decimal?     @db.Decimal(18, 4)
  prix6         Decimal?     @db.Decimal(18, 4)
  commentaire   String?
  isActive      Boolean      @default(true)
  type          ArticleType  @default(SIMPLE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  lots           StockLot[]
  movements      Movement[]
  movementLines  StockMovementLine[]
  parentKits     KitComponent[]  @relation("KitParent")
  childKits      KitComponent[]  @relation("KitChild")
  salesLines     SalesOrderLine[]
  purchaseLines  PurchaseOrderLine[]
  priceItems     PriceListItem[]
  supplierPrices SupplierPrice[]
  kitLoans       KitLoan[]

  @@index([type])
  @@index([isActive])
  @@index([code])
}

// ─────────────────────────────────────────────
// COMPOSITION DES KITS
// ─────────────────────────────────────────────

model KitComponent {
  id              Int     @id @default(autoincrement())
  parentArticleId Int
  childArticleId  Int
  quantity        Decimal @db.Decimal(18, 3)

  parentArticle Article @relation("KitParent", fields: [parentArticleId], references: [id], onDelete: Cascade)
  childArticle  Article @relation("KitChild", fields: [childArticleId], references: [id], onDelete: Restrict)

  @@unique([parentArticleId, childArticleId])
  @@index([childArticleId])
}

// ─────────────────────────────────────────────
// SUIVI PRÊTS / DÉMOS / VENTES DE KITS
// ─────────────────────────────────────────────

model KitLoan {
  id         Int           @id @default(autoincrement())
  articleId  Int
  customerId Int
  type       KitLoanType
  status     KitLoanStatus @default(EN_COURS)
  sentAt     DateTime      @default(now())
  returnedAt DateTime?
  contact    String?
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  article  Article  @relation(fields: [articleId], references: [id], onDelete: Restrict)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([articleId])
  @@index([customerId])
  @@index([status])
  @@index([type])
}

// ─────────────────────────────────────────────
// STOCK — LOTS
// ─────────────────────────────────────────────

model StockLot {
  id          Int        @id @default(autoincrement())
  articleId   Int
  lotNumber   String
  quantity    Decimal    @db.Decimal(18, 3)
  status      LotStatus  @default(AVAILABLE)
  coutRevient Decimal?   @db.Decimal(18, 4)
  supplierId  Int?
  receivedAt  DateTime?
  expiryDate  DateTime?
  locationId  Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  location  Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  movements Movement[]
  lines     StockMovementLine[]

  @@unique([articleId, lotNumber])
  @@index([articleId])
  @@index([supplierId])
  @@index([status])
  @@index([locationId])
}

// ─────────────────────────────────────────────
// STOCK — MOTIFS DE MOUVEMENT
// ─────────────────────────────────────────────

model MovementReason {
  id        Int               @id @default(autoincrement())
  code      String            @unique
  label     String
  direction MovementDirection
  isActive  Boolean           @default(true)

  movements Movement[]
}

// ─────────────────────────────────────────────
// STOCK — MOUVEMENTS
// ─────────────────────────────────────────────

model Movement {
  id             Int               @id @default(autoincrement())
  movedAt        DateTime          @default(now())
  direction      MovementDirection
  type           MovementType
  quantity       Decimal           @db.Decimal(18, 4)
  referenceType  String
  referenceId    String
  note           String?
  reasonId       Int?
  itemId         Int
  lotId          Int?
  createdById    Int
  fromLocationId Int?
  toLocationId   Int?

  reason       MovementReason? @relation(fields: [reasonId], references: [id], onDelete: SetNull)
  item         Article         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot          StockLot?       @relation(fields: [lotId], references: [id], onDelete: SetNull)
  createdBy    User            @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fromLocation Location?       @relation("FromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation   Location?       @relation("ToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  lines        StockMovementLine[]

  @@index([itemId])
  @@index([lotId])
  @@index([movedAt])
  @@index([reasonId])
  @@index([type])
}

model StockMovementLine {
  id              Int                @id @default(autoincrement())
  movementId      Int
  articleId       Int
  lotId           Int?
  quantity        Decimal            @db.Decimal(18, 3)
  unitCost        Decimal?           @db.Decimal(18, 4)
  sourceLotNumber String?
  targetLotNumber String?
  isKitExplosion  Boolean            @default(false)
  parentLineId    Int?

  movement   Movement           @relation(fields: [movementId], references: [id], onDelete: Cascade)
  article    Article            @relation(fields: [articleId], references: [id], onDelete: Restrict)
  lot        StockLot?          @relation(fields: [lotId], references: [id], onDelete: SetNull)
  parentLine StockMovementLine? @relation("LineTree", fields: [parentLineId], references: [id], onDelete: SetNull)
  children   StockMovementLine[] @relation("LineTree")

  @@index([movementId])
  @@index([articleId])
  @@index([lotId])
}

// ─────────────────────────────────────────────
// COMMANDES CLIENT
// ─────────────────────────────────────────────

model SalesOrder {
  id               Int       @id @default(autoincrement())
  number           String    @unique
  customerId       Int?
  status           DocStatus @default(DRAFT)
  referenceClient  String?
  numDevis         String?
  devise           String    @default("EUR")
  delai            String?
  createdAt        DateTime  @default(now())
  dateFacturation  DateTime?
  dateEncaissement DateTime?
  prixTotal        Decimal?  @db.Decimal(18, 2)
  commentaire      String?

  customer      Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines         SalesOrderLine[]
  deliveryNotes DeliveryNote[]

  @@index([customerId])
}

model SalesOrderLine {
  id        Int      @id @default(autoincrement())
  orderId   Int
  itemId    Int
  qty       Decimal  @db.Decimal(18, 4)
  qtyDone   Decimal  @default(0) @db.Decimal(18, 4)
  unitPrice Decimal? @db.Decimal(18, 4)
  prixTotal Decimal? @db.Decimal(18, 4)

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  Article    @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([itemId])
}

// ─────────────────────────────────────────────
// COMMANDES FOURNISSEUR
// ─────────────────────────────────────────────

model PurchaseOrder {
  id                   Int       @id @default(autoincrement())
  number               String    @unique
  supplierId           Int?
  status               DocStatus @default(DRAFT)
  refDevisFournisseur  String?
  dateDevisFournisseur DateTime?
  createdAt            DateTime  @default(now())
  dateLivraisonPrevue  DateTime?
  dateLivraisonReelle  DateTime?
  commentaire          String?

  supplier Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines    PurchaseOrderLine[]

  @@index([supplierId])
}

model PurchaseOrderLine {
  id        Int      @id @default(autoincrement())
  orderId   Int
  itemId    Int
  qty       Decimal  @db.Decimal(18, 4)
  qtyDone   Decimal  @default(0) @db.Decimal(18, 4)
  unitPrice Decimal? @db.Decimal(18, 4)
  lotNumber String?

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  Article       @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([itemId])
}

// ─────────────────────────────────────────────
// BONS DE LIVRAISON & FACTURES
// ─────────────────────────────────────────────

model DeliveryNote {
  id        Int       @id @default(autoincrement())
  number    String    @unique
  orderId   Int
  status    DocStatus @default(DRAFT)
  createdAt DateTime  @default(now())

  order    SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([orderId])
}

model Invoice {
  id               Int       @id @default(autoincrement())
  number           String    @unique
  blId             Int
  status           DocStatus @default(DRAFT)
  amount           Decimal   @db.Decimal(18, 2)
  createdAt        DateTime  @default(now())
  dateEcheance     DateTime?
  dateEncaissement DateTime?
  commentaire      String?

  deliveryNote DeliveryNote @relation(fields: [blId], references: [id], onDelete: Cascade)

  @@index([blId])
}
